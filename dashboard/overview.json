{
  "dashboard": {
    "title": "RF Analyzer V2 Overview",
    "tags": ["rf", "analyzer", "v2"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Total Packets",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
        "targets": [
          {"expr": "packets_captured_total", "refId": "A"}
        ]
      },
      {
        "id": 2,
        "title": "Threats Detected",
        "type": "stat",
        "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
        "targets": [
          {"expr": "threats_detected_total", "refId": "A"}
        ]
      },
      {
        "id": 3,
        "title": "ML Predictions",
        "type": "stat",
        "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
        "targets": [
          {"expr": "ml_predictions_total", "refId": "A"}
        ]
      },
      {
        "id": 4,
        "title": "Active Alerts",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
        "targets": [
          {"expr": "alerts_sent_total", "refId": "A"}
        ]
      },
      {
        "id": 5,
        "title": "Network Traffic",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {"expr": "rate(packets_captured_total[5m])", "refId": "A"}
        ]
      },
      {
        "id": 6,
        "title": "Signal Distribution",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {"expr": "signals_by_protocol", "refId": "A"}
        ]
      }
    ]
  }
}
