    9000: {'name': 'SonarQube', 'risk': 'high', 'vuln': 'Code exposure'},
    9200: {'name': 'Elasticsearch', 'risk': 'critical', 'vuln': 'Data exposure'},
    27017: {'name': 'MongoDB', 'risk': 'critical', 'vuln': 'No auth by default'},
}

# Device risk profiles
RISK_PROFILES = {
    'Router/Gateway': {'base_risk': 50, 'vulns': ['weak_default_credential']},
    'IoT Camera': {'base_risk': 70, 'vulns': ['default_password', 'unencrypted_stream']},
    'Smart TV': {'base_risk': 40, 'vulns': ['casting_vuln']},
    'Smart Speaker': {'base_risk': 50, 'vulns': ['microphone_access']},
    'Smart Home Hub': {'base_risk': 60, 'vulns': ['central_vuln']},
    'ESP32': {'base_risk': 55, 'vulns': ['weak_wifi', 'no_encryption']},
    'Raspberry Pi': {'base_risk': 35, 'vulns': ['default_pi_user']},
    'VM': {'base_risk': 20, 'vulns': []},
    'Unknown': {'base_risk': 50, 'vulns': ['unidentified']},
}

class MLEngine:
    def __init__(self):
        self.client = MongoClient(MONGODB_URL)
        self.db = self.client['rf_analyzer_v2']
        
    def get_vendor(self, mac):
        if not mac or mac == 'unknown':
            return 'Unknown'
        prefix = mac.replace(':', '').replace('-', '').upper()[:6]
        return OUI_VENDORS.get(prefix, 'Unknown')
    
    def detect_vulnerabilities(self, device):
        """Detecta vulnerabilidades basadas en puertos y servicios"""
        vulns = []
        risk_score = 0
        ports = device.get('open_ports', [])
        
        if not ports:
            # Check signals for port info
            signals = list(self.db.signals.find({'src_ip': device.get('ip')}).limit(100))
            ports = list(set(s.get('port', 0) for s in signals if s.get('port')))
        
        for port in ports:
            if port in VULNERABLE_SERVICES:
                vuln = VULNERABLE_SERVICES[port]
                vulns.append({
                    'port': port,
                    'service': vuln['name'],
                    'risk_level': vuln['risk'],
                    'vulnerability': vuln['vuln']
                })
                if vuln['risk'] == 'critical':
                    risk_score += 30
                elif vuln['risk'] == 'high':
                    risk_score += 20
                elif vuln['risk'] == 'medium':
                    risk_score += 10
        
        # Check for suspicious patterns
        ip = device.get('ip', '')
        traffic_types = device.get('traffic_types', [])
        
        # Known vulnerable patterns
        if 'telnet' in traffic_types:
            vulns.append({'port': 23, 'service': 'Telnet', 'risk_level': 'critical', 'vulnerability': 'Unencrypted access'})
            risk_score += 30
            
        if 'ftp' in traffic_types:
            vulns.append({'port': 21, 'service': 'FTP', 'risk_level': 'high', 'vulnerability': 'Unencrypted'})
            risk_score += 20
            
        # Cloud IPs are less concerning
        if not ip.startswith('192.168.'):
            risk_score = max(0, risk_score - 20)
            
        return {'vulnerabilities': vulns, 'risk_score': min(100, risk_score)}
    
    def classify_device(self, device):
        ip = device.get('ip', '')
        mac = device.get('mac', '')
        traffic = device.get('traffic_types', [])
        ports = device.get('open_ports', [])
        
        vendor = self.get_vendor(mac)
        
        # Determine device type
        if ip.endswith('.1') or ip == '192.168.1.1':
            device_type = 'Router/Gateway'
        elif 'Raspberry' in vendor or 'RPi' in vendor:
            device_type = 'SBC'
        elif 'VMware' in vendor or 'VirtualBox' in vendor or 'Parallels' in vendor:
            device_type = 'VM'
        elif 'Apple' in vendor:
            device_type = 'Apple Device'
        elif 'ESP' in vendor or 'Espressif' in vendor:
            device_type = 'ESP32'
        elif vendor in ['Amazon', 'Xiaomi', 'Samsung', 'TP-Link', 'D-Link', 'NETGEAR', 'Linksys', 'Cisco']:
            # Check traffic for specific type
            if 'mqtt' in traffic:
                device_type = 'IoT Device'
            elif 'mdns' in traffic:
                device_type = 'Apple Device'
            else:
                device_type = 'Smart Device'
        elif 'mdns' in traffic:
            device_type = 'Apple Device'
        elif 'mqtt' in traffic:
            device_type = 'IoT Device'
        elif 'homeassistant' in traffic:
            device_type = 'Smart Home Hub'
        elif 'google' in vendor.lower() or 'chromecast' in vendor.lower():
            device_type = 'Smart Speaker/Display'
        else:
            device_type = 'Unknown'
        
        # Get vulnerabilities
        vuln_info = self.detect_vulnerabilities(device)
        
        # Calculate final risk
        base_risk = RISK_PROFILES.get(device_type, RISK_PROFILES['Unknown'])['base_risk']
        risk_score = min(100, base_risk + vuln_info['risk_score'])
        
        return {
            'vendor': vendor,
            'device_type': device_type,
            'vulnerabilities': vuln_info['vulnerabilities'],
            'risk_score': risk_score,
            'risk_factors': RISK_PROFILES.get(device_type, {}).get('vulns', [])
        }
    
    def run_classification(self):
        devices = list(self.db.devices.find())
        results = {'classified': 0, 'high_risk': 0, 'critical': 0}
        
        for dev in devices:
            cls = self.classify_device(dev)
            self.db.devices.update_one(
                {'ip': dev['ip']},
                {'$set': {
                    'vendor': cls['vendor'],
                    'device_type': cls['device_type'],
                    'vulnerabilities': cls['vulnerabilities'],
                    'risk_score': cls['risk_score'],
                    'risk_factors': cls['risk_factors'],
                    'ml_classified': True,
                    'last_ml_scan': datetime.now().isoformat()
                }}
            )
            results['classified'] += 1
            if cls['risk_score'] >= 70:
                results['critical'] += 1
            elif cls['risk_score'] >= 50:
                results['high_risk'] += 1
        
        return results

if __name__ == '__main__':
    ml = MLEngine()
    print(ml.run_classification())
