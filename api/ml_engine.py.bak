# Known vulnerable services
VULNERABLE_SERVICES = {
    21: {'name': 'FTP', 'risk': 'high', 'vuln': 'Unencrypted, easy target'},
    23: {'name': 'Telnet', 'risk': 'critical', 'vuln': 'No encryption, easy compromise'},
    25: {'name': 'SMTP', 'risk': 'medium', 'vuln': 'Open relay'},
    53: {'name': 'DNS', 'risk': 'medium', 'vuln': 'DNS spoofing'},
