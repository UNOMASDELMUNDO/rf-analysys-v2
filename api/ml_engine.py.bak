    515: {'name': 'LPD', 'risk': 'low', 'vuln': 'Printer'},
    1433: {'name': 'MSSQL', 'risk': 'critical', 'vuln': 'Data breach'},
    1521: {'name': 'Oracle', 'risk': 'critical', 'vuln': 'Data breach'},
